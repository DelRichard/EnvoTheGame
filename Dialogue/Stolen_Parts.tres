[ext_resource type="Script" uid="uid://dmp1iu63or1av" path="res://Scripts/DialogueData.gd" id="1_6i6gd"]

[resource]
script = ExtResource("1_6i6gd")
lines = Array[String](["Ah there you are frien'. Not far from here is my machine that will restore this waste land into what we once were", "But those lil radishes are at it again", "They done stole my machine parts gosh darn it", "Clean water, frien'. Do you know what that would mean for this village?", "People are dying of thirst. That's not a natural disaster. That is a crime", "Without the water our lil faming community here ceases to exist", "And we'll slowly die out", "Be a lad and fetch dem parts from dem critters"])
metadata/_custom_type_script = "uid://dmp1iu63or1av"
