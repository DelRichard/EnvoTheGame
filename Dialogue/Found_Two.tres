[resource]
script = ExtResource("1_sthji")
lines = Array[String](["Good work kid you found some of the missing parts but we're still missing one", "Hold on there buckoo...", "There's been a bit of a kerfuffle that needs our attention", "A pumpkin veggion was spotted near the lake", "Some of our village folk that were going in that direction haven't made it back", "Looks like my machine will have to wait for now", "I saw a young lad near the bridge that managed to flee", "We should go check the situation out"])
