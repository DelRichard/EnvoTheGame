script = ExtResource("1_gf6rc")
lines = Array[String](["Huh...?", "Who goes there?", "A filthy field rat.", "We have no business with you.", "Nothing from the fields passes this gate. Not disease. Not drought. Not whatever you are. Turn around.", "Your people should have stopped them when they first started dumping into it. Not our problem that you didn't.", "...", "What's that rumbling?"])
