[ext_resource type="Script" uid="uid://dmp1iu63or1av" path="res://Scripts/DialogueData.gd" id="1_amq1h"]

[resource]
script = ExtResource("1_amq1h")
lines = Array[String](["You actually came back. Good. Most people who find out I'm the one waiting for them turn right around.", "Now I can work on my machine again. The Neon City took everything from us the water, the air, the dirt under our feet. But they cannot take what I know. Not yet anyway.", "The land can recover the problem was never the land itself. It was who was allowed to destroy it without consequence.", "You know what the Neon City's smartest move was?", "It wasn't the factories. It wasn't the walls. It was making sure we had nothing left to fight with. No food. No water. No strength. Hungry people can't stand up. Thirsty people can't think straight.", "They didn't destroy us with weapons, kid. They destroyed us with neglect.
Poverty is manufactured. Unequal access to resources is the weapon and it's invisible enough to look like bad luck.", "But a wrench is a start. Come I will show you what neglect looks like when it decides to fight back."])
metadata/_custom_type_script = "uid://dmp1iu63or1av"
