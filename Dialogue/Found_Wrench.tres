[ext_resource type="Script" uid="uid://dmp1iu63or1av" path="res://Scripts/DialogueData.gd" id="1_amq1h"]

[resource]
script = ExtResource("1_amq1h")
lines = Array[String](["Well I'll be frien' you made it back", "Most folk would just turn the other way for Ol' Goldfoot", "Ah yes you found my wrench now I can finally finish my doodad", "Our only downfall is not the poor soil", "It's the fact that we let it happen in the first place", "You know what dem concrete heads smartest move was?", "It wasn't the factories. It wasn't the walls", "It was making sure we had nothing left to fight with. No food. No water. No strength. Hungry people can't stand up. Thirsty people can't think straight", "They didn't destroy us with weapons, kid. They destroyed us with neglect. Poverty is manufactured", "Unequal access to resources is the weapon and it's invisible enough to look like bad luck", "Come I will show you what neglect looks like when it decides to fight back"])
metadata/_custom_type_script = "uid://dmp1iu63or1av"
