[ext_resource type="Script" uid="uid://dmp1iu63or1av" path="res://Scripts/DialogueData.gd" id="1_ri8li"]

[resource]
script = ExtResource("1_ri8li")
lines = Array[String](["Well howdy there fella so you're rascal that lives in this here treehouse", "You frien' are either extraordinarily lucky or extraordinarily crazy", "I haven't decided which", "Dem village folk used to say the same thing about good Ol' GoldFoot", "\"Goldfoot's crazy\" \"Goldfoot's wasting his time\" 
\"He should just give up\" ", "Meanwhile half of this gosh darn village is eating bark soup, and the other half isn't eating at all", "But once my  doohickey thingamajig is fixed it'll get rid of all this here waste", "Dem city folk took everything from us the water, air heck even the dirt under our feet", "The land can recover the problem was never the land itself. It was who was allowed to destroy it without consequence.", "Listen frien'. I dropped my trusted left handed wrench somewhere aroun' this here parts.", "And my lil Ol' legs are one week away from being crippled", "Be a pal and help n' fecthin' it for me"])
metadata/_custom_type_script = "uid://dmp1iu63or1av"
